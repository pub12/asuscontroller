# .env.example — NetWarden environment variables
# Copy this file to .env and fill in real values.
# IMPORTANT: Never commit .env with real values — it is gitignored.
# This file (.env.example) is safe to commit (contains no secrets).

# --- Core ---
HAZO_ENV=development

# --- Auth (required at runtime) ---
HAZO_AUTH_COOKIE_PREFIX=netwarden_
# IMPORTANT: Change JWT_SECRET to a long random string before deploying.
JWT_SECRET=change-me-to-a-long-random-string
SUPERADMIN_EMAIL=admin@netwarden.local
SUPERADMIN_PASSWORD=changeme1234

# --- Field encryption (EnvKeyProvider prefix: HAZO_FIELD_KEY) ---
# IMPORTANT: Generate real key material with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Never commit real key values.
HAZO_FIELD_KEY_CURRENT=v1
HAZO_FIELD_KEY_v1=change-me-32-byte-key-base64-encoded

# --- Router (ASUS ZenWiFi) — used by staged spike scripts only, never run unattended ---
ROUTER_HOST=192.168.50.1
ROUTER_USER=admin
ROUTER_PASS=
# MAC address of the guinea-pig device for spike/test isolation
SPIKE_TEST_MAC=AA:BB:CC:DD:EE:FF

# --- Device sync ---
# Router data source: "fake" (default, in-memory test provider) or "asus" (real router; staged, do not use yet)
ROUTER_PROVIDER=fake
# How often the sync worker polls the router, in seconds (default 60)
SYNC_INTERVAL_SEC=60

# --- Telemetry ---
# TODO: telemetry provider undecided (NextDNS preferred). Leave unset until chosen.
NEXTDNS_API_KEY=

# --- Notifications (hazo_notify → Telegram, best-effort operational alerts) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Retention ---
# Days to keep raw app_domain_events before daily pruning (rollups are retained)
RAW_EVENT_RETENTION_DAYS=30
